{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:automergeDaily",
    "schedule:daily"
  ],
  "baseBranchPatterns": ["main", "nixos-25.11", "nixos-26.05"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "nix": {
    "enabled": true
  }
}
